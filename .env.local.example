# 이 파일을 .env.local 로 복사한 뒤 값을 채우세요. (.env.local 은 커밋 금지)

# --- AI 프록시 (서버 전용 · 브라우저에 절대 노출 안 됨) ---
# https://console.groq.com → API Keys 에서 발급 (무료 티어 1,000건/일, 카드 등록 불필요). 키는 gsk_ 로 시작.
GROQ_API_KEY=gsk_xxxxxxxx

# --- Supabase (명예의전당 DB) ---
# Supabase 프로젝트 → Project Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- 배포 주소 (OG 썸네일 절대경로용 · 선택) ---
# 미설정 시 로컬은 http://localhost:3000 로 동작. Vercel 배포 후 프로덕션 URL 로 채우면 공유 미리보기가 정확해짐.
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
